    "No prompts, no rules. Worries, plans, nonsense — let it spill." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بلا مطالبات، بلا قواعد. الهموم، الخطط، الهراء — دعها تنسكب."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keine Vorgaben, keine Regeln. Sorgen, Pläne, Unsinn — lass es raus."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sin indicaciones, sin reglas. Preocupaciones, planes, tonterías — déjalo salir."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pas de consignes, pas de règles. Soucis, projets, bêtises — laisse tout sortir."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niente spunti, niente regole. Preoccupazioni, piani, sciocchezze — lascia che escano."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "お題もルールもなし。悩みも、計画も、たわごとも——そのまま溢れさせよう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "질문도 규칙도 없어요. 걱정, 계획, 잡생각 — 그냥 쏟아내세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geen prompts, geen regels. Zorgen, plannen, onzin — laat het eruit stromen."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sem sugestões, sem regras. Preocupações, planos, disparates — deixe tudo sair."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Никаких подсказок и правил. Тревоги, планы, чепуха — пусть всё выльется наружу."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "没有提示，没有规则。烦恼、计划、胡思乱想——都倾诉出来吧。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "沒有提示，沒有規則。煩惱、計劃、胡思亂想——都傾訴出來吧。"
          }
        }
      }
    },
