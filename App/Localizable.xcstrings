    "handed to the scroll — gone before\nyou're even awake." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تُهدى للتمرير — تضيع قبل\nأن تستيقظ."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "dem Scrollen geopfert — weg, bevor\ndu überhaupt wach bist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "entregadas al scroll — perdidas antes\nde despertar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "données au scroll — envolées avant\nmême ton réveil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "regalate allo scroll — svanite prima\nancora di svegliarti."
