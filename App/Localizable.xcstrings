            "value" : "Lembretes de afirmações"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Напоминания об аффирмациях"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "肯定语提醒"
          }
        },
