            "value" : "今天讓這一頁安靜——這也算數。"
          }
        }
      }
    },
    "Let's carve out a few minutes that are only yours." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لنقتطع بضع دقائق لك وحدك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schaffen wir ein paar Minuten, die nur dir gehören."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reservemos unos minutos que sean solo tuyos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réservons quelques minutes rien qu’à toi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ritagliamo qualche minuto solo per te."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなただけの数分を、つくろう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "오직 당신만의 몇 분을 마련해요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Laten we een paar minuten vrijmaken die alleen van jou zijn."
