        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "폰에서 벗어나 진짜 하루로 들어가요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Laten we je van de telefoon halen en je echte dag in."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vamos tirar você do celular e levar ao seu dia de verdade."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оторвём тебя от телефона — в настоящий день."
          }
        },
        "zh-Hans" : {
