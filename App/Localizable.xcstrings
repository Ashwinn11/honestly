    "If today had one job, what would it be?" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا كان اليوم لديه وظيفة واحدة، فماذا ستكون ؟"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn heute ein Job wäre, welcher wäre das?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si hoy tuviera un trabajo, ¿cuál sería?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si aujourd'hui il y avait un emploi, quel serait-il ?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se oggi avessi un solo lavoro, quale sarebbe?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今日1つの仕事があるとしたら、それは何ですか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "오늘날 한 가지 직업이 있다면, 그것은 무엇일까요?"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Als vandaag één baan had, wat zou dat dan zijn?"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se hoje tivesse um emprego, qual seria?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если бы сегодня была одна работа, что бы это было?"
          }
        },
