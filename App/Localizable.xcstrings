    "Longest yet — keep the sun rising." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أطول مدة حتى الآن — دع الشمس تشرق."
          }
        },
        "de" : {
