    "%lld apps stay asleep until you write. A few quiet minutes, just for you." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "‏%lld تطبيقات تبقى نائمة حتى تكتب. بضع دقائق هادئة، لك وحدك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld Apps schlafen, bis du schreibst. Ein paar stille Minuten, nur für dich."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld apps duermen hasta que escribas. Unos minutos tranquilos, solo para ti."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld apps dorment jusqu’à ce que tu écrives. Quelques minutes calmes, rien qu’à toi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld app dormono finché non scrivi. Qualche minuto di calma, solo per te."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld個のアプリが書くまで眠ってる。あなただけの静かな数分。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "앱 %lld개가 쓸 때까지 잠들어 있어요. 오직 당신만의 조용한 몇 분."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld apps slapen tot je schrijft. Een paar stille minuten, alleen voor jou."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld apps dormem até você escrever. Alguns minutos calmos, só para você."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld приложений спят, пока ты не напишешь. Несколько тихих минут только для тебя."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 个应用在你写字前一直沉睡。几分钟安静，只属于你。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 個應用在你寫字前一直沉睡。幾分鐘安靜，只屬於你。"
          }
        }
      }
    },
