        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Honestly é fornecido \"como está\". Trabalhamos para mantê-lo confiável, mas não podemos prometer que será ininterrupto ou sem erros, e ele não substitui cuidados profissionais de saúde mental."
          }
        },
