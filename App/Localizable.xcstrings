    "Left the page quiet today — and that counts too." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تركتُ الصفحة صامتة اليوم — وهذا يُحتسب أيضًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Heute die Seite still gelassen — auch das zählt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoy dejé la página en silencio — y eso también cuenta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Page laissée silencieuse aujourd’hui — ça compte aussi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oggi ho lasciato la pagina in silenzio — conta anche questo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今日はページを静かに — それも大事。"
