        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei arrivato prima del mondo. È tutto qui."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "世界より先に、あなたが来た。それがすべて。"
