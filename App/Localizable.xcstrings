            "value" : "スクロールに渡した — 目覚める前に\n消えてしまう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "스크롤에 넘겨준 — 깨기도 전에\n사라진."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "aan het scrollen gegeven — weg voor\nje wakker bent."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "entregues ao scroll — perdidas antes\nde você acordar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "отданных ленте — исчезают ещё\nдо пробуждения."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "交给了刷屏——还没醒\n就没了。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "交給了滑動——還沒醒\n就沒了。"
          }
        }
      }
    },
