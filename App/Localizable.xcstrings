        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "오늘은 페이지를 비워뒀어요 — 그것도 괜찮아요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vandaag de pagina stil gelaten — dat telt ook."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deixei a página em silêncio hoje — e isso também conta."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сегодня оставил страницу пустой — это тоже считается."
