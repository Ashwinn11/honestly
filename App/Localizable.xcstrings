    "“Meet yourself before the world logs on.”" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«قابِل نفسك قبل أن يتّصل العالم.»"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Begegne dir selbst, bevor die Welt online geht.“"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Encuéntrate antes de que el mundo se conecte.»"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« Retrouve-toi avant que le monde se connecte. »"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Incontra te stesso prima che il mondo si colleghi.»"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「世界がログインする前に、自分に会おう。」"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“세상이 접속하기 전에 나를 만나요.”"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Ontmoet jezelf voor de wereld inlogt.”"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Encontre-se antes de o mundo entrar online.”"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Встреть себя, пока мир не вошёл в сеть.»"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“在世界上线之前，先遇见自己。”"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“在世界上線之前，先遇見自己。”"
          }
        }
      }
    },
    "“The first ten minutes that are finally mine.”" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«أول عشر دقائق أصبحت أخيرًا لي.»"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Die ersten zehn Minuten, die endlich mir gehören.“"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Los primeros diez minutos que por fin son míos.»"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« Les dix premières minutes enfin à moi. »"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«I primi dieci minuti finalmente miei.»"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「やっと自分のものになった最初の10分。」"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“드디어 온전히 내 것이 된 첫 10분.”"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“De eerste tien minuten die eindelijk van mij zijn.”"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Os primeiros dez minutos que enfim são meus.”"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Первые десять минут, что наконец мои.»"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“终于属于我的头十分钟。”"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“終於屬於我的頭十分鐘。”"
          }
        }
      }
    },
