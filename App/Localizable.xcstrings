    "You showed up before the world did. That's the whole thing." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حضرتَ قبل العالم. هذا كل شيء."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du warst vor der Welt da. Das ist alles."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Llegaste antes que el mundo. Eso es todo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous étiez là avant le monde. C’est tout."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei arrivato prima del mondo. È tutto qui."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "世界より先に、あなたが来た。それがすべて。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "세상보다 먼저 왔어요. 그게 전부예요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jij was er vóór de wereld. Dat is alles."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você chegou antes do mundo. É isso."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ты пришёл раньше мира. В этом всё."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你比世界先到。这就是全部。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你比世界先到。這就是全部。"
          }
        }
      }
    },
    "You're about to join people who reclaimed their mornings — one quiet page at a time." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت على وشك الانضمام لمن استعادوا صباحاتهم — صفحة هادئة تلو الأخرى."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du schließt dich Menschen an, die sich ihre Morgen zurückgeholt haben — Seite für Seite."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estás por unirte a quienes recuperaron sus mañanas, una página tranquila a la vez."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu rejoins ceux qui ont repris leurs matins — une page tranquille à la fois."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ti unisci a chi si è ripreso le mattine — una pagina tranquilla alla volta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "朝を取り戻した人たちの仲間入り — 静かな一枚ずつ。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "아침을 되찾은 사람들과 함께해요 — 고요한 한 장씩."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je sluit je aan bij mensen die hun ochtenden heroverden — pagina voor pagina."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você vai se juntar a quem retomou as manhãs — uma página tranquila de cada vez."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ты присоединяешься к тем, кто вернул свои утра — по тихой странице за раз."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你将加入那些夺回早晨的人——一次一页安静。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你將加入那些奪回早晨的人——一次一頁安靜。"
          }
        }
      }
    },
