        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vamos reservar alguns minutos só seus."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Выкроим несколько минут только для тебя."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "为你留出几分钟，只属于你。"
