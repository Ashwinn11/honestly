    "A few mornings a week is enough — streaks build quietly" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بضع صباحات في الأسبوع تكفي — السلاسل تُبنى بهدوء"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein paar Morgen pro Woche reichen — Streaks wachsen leise"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Con unas pocas mañanas a la semana basta — las rachas se construyen en silencio"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quelques matins par semaine suffisent — les séries se construisent en douceur"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bastano poche mattine a settimana — le serie si costruiscono in silenzio"
