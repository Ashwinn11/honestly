    "A couple of minutes. Worries, plans, nonsense — let it spill." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "دقيقتان. الهموم والخطط والهراء — دعها تتدفّق."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein paar Minuten. Sorgen, Pläne, Unsinn — lass es raus."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un par de minutos. Preocupaciones, planes, tonterías — suéltalo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deux minutes. Soucis, plans, absurdités — laisse couler."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un paio di minuti. Preoccupazioni, piani, sciocchezze — lascia uscire."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "数分だけ。心配も予定もくだらないことも、書き出して。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "몇 분이면 돼요. 걱정, 계획, 헛소리 — 다 쏟아내요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Een paar minuten. Zorgen, plannen, onzin — laat het stromen."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uns minutos. Preocupações, planos, bobagens — deixe sair."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пара минут. Тревоги, планы, чепуха — выпусти всё."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "几分钟就好。烦恼、计划、废话——都倒出来。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "幾分鐘就好。煩惱、計劃、廢話——都倒出來。"
          }
        }
      }
    },
