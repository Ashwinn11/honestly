    "Left the page quiet today — and that counts too." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تركتُ الصفحة صامتة اليوم — وهذا يُحتسب أيضًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Heute die Seite still gelassen — auch das zählt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoy dejé la página en silencio — y eso también cuenta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Page laissée silencieuse aujourd’hui — ça compte aussi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oggi ho lasciato la pagina in silenzio — conta anche questo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今日はページを静かに — それも大事。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "오늘은 페이지를 비워뒀어요 — 그것도 괜찮아요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vandaag de pagina stil gelaten — dat telt ook."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deixei a página em silêncio hoje — e isso também conta."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сегодня оставил страницу пустой — это тоже считается."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今天让这一页安静——这也算数。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今天讓這一頁安靜——這也算數。"
          }
        }
      }
    },
    "Let's carve out a few minutes that are only yours." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لنقتطع بضع دقائق لك وحدك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schaffen wir ein paar Minuten, die nur dir gehören."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reservemos unos minutos que sean solo tuyos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réservons quelques minutes rien qu’à toi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ritagliamo qualche minuto solo per te."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなただけの数分を、つくろう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "오직 당신만의 몇 분을 마련해요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Laten we een paar minuten vrijmaken die alleen van jou zijn."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vamos reservar alguns minutos só seus."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Выкроим несколько минут только для тебя."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "为你留出几分钟，只属于你。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "為你留出幾分鐘，只屬於你。"
          }
        }
      }
    },
    "Let's clear the morning fog before the world fills it." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لنبدّد ضباب الصباح قبل أن يملأه العالم."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vertreiben wir den Morgennebel, bevor die Welt ihn füllt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Despejemos la niebla matutina antes de que el mundo la llene."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dissipons le brouillard du matin avant que le monde ne le remplisse."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diradiamo la nebbia del mattino prima che il mondo la riempia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "世界が埋める前に、朝の霧を晴らそう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "세상이 채우기 전에 아침 안개를 걷어내요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Laten we de ochtendmist verdrijven voor de wereld hem vult."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vamos dissipar a névoa da manhã antes de o mundo preenchê-la."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Развеем утренний туман, пока мир его не заполнил."
