    "Your longest yet. Keep the sun rising." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أطول مدة حتى الآن. دع الشمس تشرق."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bisher am längsten. Lass die Sonne aufgehen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu récord. Que siga saliendo el sol."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ton record. Garde le soleil levant."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tuo record. Fai sorgere il sole."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自己ベスト。太陽を昇らせ続けて。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "최고 기록이에요. 계속 해를 띄워요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je langste ooit. Laat de zon opkomen."
          }
        },
