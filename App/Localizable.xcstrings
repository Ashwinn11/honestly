    "Let's get you off the phone and into your actual day." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لنبعدك عن الهاتف وندخلك في يومك الحقيقي."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bringen wir dich weg vom Handy und in deinen echten Tag."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vamos a sacarte del móvil y meterte en tu día real."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sortons-toi du téléphone pour entrer dans ta vraie journée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stacchiamoti dal telefono e portiamoti nella tua vera giornata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スマホから離れて、本当の一日へ。"
