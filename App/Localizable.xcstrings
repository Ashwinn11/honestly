    "If today is just about getting through, what does that look like?" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إن كان اليوم مجرّد تجاوُز، فكيف يبدو ذلك؟"
