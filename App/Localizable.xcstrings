    "No badges, no bait — just a nudge to meet yourself before the day does." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا شارات ولا إغراء — مجرد تذكير لتلتقي بنفسك قبل أن يبدأ اليوم."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keine Badges, kein Köder — nur ein Anstoß, dir selbst zu begegnen, bevor der Tag es tut."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sin globos ni anzuelos — solo un aviso para encontrarte antes que el día."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pas de pastilles, pas d’appât — juste un rappel pour te retrouver avant le jour."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niente badge, niente esche — solo un invito a incontrarti prima del giorno."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "バッジも釣りもなし — 一日より先に自分と会うためのひと押し。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "배지도 미끼도 없이 — 하루보다 먼저 나를 만나라는 넛지."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geen badges, geen aas — alleen een duwtje om jezelf te ontmoeten voor de dag dat doet."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sem selos, sem iscas — só um empurrão para se encontrar antes do dia."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Без бейджей и приманок — лишь толчок встретить себя раньше дня."
