    "The apps stay asleep until I've written — so the morning feels calm again." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تبقى التطبيقات نائمة حتى أكتب — فيعود الصباح هادئًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Apps schlafen, bis ich geschrieben habe — so wird der Morgen wieder ruhig."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las apps duermen hasta que escribo — así la mañana vuelve a ser tranquila."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les apps dorment jusqu’à ce que j’écrive — le matin redevient calme."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le app dormono finché non scrivo — così la mattina torna calma."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "書き終えるまでアプリは眠る — だから朝がまた穏やかに。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다 쓸 때까지 앱은 잠들어요 — 그래서 아침이 다시 차분해져요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De apps slapen tot ik geschreven heb — zo wordt de ochtend weer rustig."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os apps dormem até eu escrever — então a manhã fica calma de novo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Приложения спят, пока не напишу — и утро снова спокойно."
