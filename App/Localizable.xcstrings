        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "일주일에 몇 번이면 충분해요 — 스트릭은 조용히 쌓여가요"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
