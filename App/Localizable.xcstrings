    "Good morning. Your page is waiting — the world can hold on a minute." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "صباح الخير. صفحتك تنتظر — يستطيع العالم أن ينتظر دقيقة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Guten Morgen. Deine Seite wartet — die Welt kann eine Minute warten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buenos días. Tu página espera — el mundo puede esperar un minuto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bonjour. Ta page t’attend — le monde peut patienter une minute."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buongiorno. La tua pagina aspetta — il mondo può attendere un minuto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "おはよう。ページが待ってる — 世界は少し待てる。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "좋은 아침. 당신의 페이지가 기다려요 — 세상은 잠깐 기다릴 수 있어요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Goedemorgen. Je pagina wacht — de wereld kan even wachten."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bom dia. Sua página espera — o mundo pode esperar um minuto."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доброе утро. Твоя страница ждёт — мир может подождать минуту."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "早安。你的一页在等你——世界可以等一分钟。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "早安。你的一頁在等你——世界可以等一分鐘。"
          }
        }
      }
    },
