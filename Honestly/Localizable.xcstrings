    "let us guard your morning peace" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "دعنا نحمي سلام صباحك"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "lass uns deine Morgenruhe schützen"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "deja que protejamos la paz de tu mañana"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
