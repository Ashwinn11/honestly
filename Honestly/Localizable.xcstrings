{
  "sourceLanguage" : "en",
  "strings" : {
    "- Journal data remains on-device unless you delete it" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- تبقى بيانات اليوميات على الجهاز ما لم تحذفها"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Tagebuchdaten bleiben auf dem Gerät, sofern du sie nicht löschst"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Los datos del diario permanecen en el dispositivo a menos que los elimines"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Les données du journal restent sur l'appareil sauf si vous les supprimez"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- I dati del diario restano sul dispositivo finché non li elimini"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- 日記データは削除しない限り端末内に残ります"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- 일기 데이터는 삭제하지 않는 한 기기에 남아 있습니다"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Dagboekgegevens blijven op het apparaat tenzij je ze verwijdert"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Os dados do diário permanecem no dispositivo a menos que você os exclua"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Os dados do diário permanecem no dispositivo a menos que os elimines"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Данные дневника остаются на устройстве, пока вы их не удалите"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- 除非你删除，日记数据将保留在设备上"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- 除非你刪除，日記資料將保留在裝置上"
          }
        }
      }
    },
    "- Journal entries are stored securely on-device using Apple's protected local storage" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- تُخزَّن مدخلات اليوميات بأمان على الجهاز باستخدام التخزين المحلي المحمي من Apple"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Tagebucheinträge werden sicher auf dem Gerät in Apples geschütztem lokalem Speicher abgelegt"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Las entradas del diario se guardan de forma segura en el dispositivo usando el almacenamiento local protegido de Apple"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Les entrées du journal sont stockées en toute sécurité sur l'appareil via le stockage local protégé d'Apple"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Le voci del diario sono archiviate in modo sicuro sul dispositivo usando l'archiviazione locale protetta di Apple"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- 日記はAppleの保護されたローカルストレージを使って端末内に安全に保存されます"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- 일기는 Apple의 보호된 로컬 저장소를 사용해 기기에 안전하게 저장됩니다"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Dagboekitems worden veilig op het apparaat opgeslagen via Apples beschermde lokale opslag"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- As entradas do diário ficam armazenadas com segurança no dispositivo usando o armazenamento local protegido da Apple"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- As entradas do diário ficam guardadas em segurança no dispositivo usando o armazenamento local protegido da Apple"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Записи дневника надёжно хранятся на устройстве в защищённом локальном хранилище Apple"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- 日记条目通过 Apple 的受保护本地存储安全地保存在设备上"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- 日記條目透過 Apple 的受保護本機儲存安全地保存在裝置上"
          }
        }
      }
    },
    "- Payment is charged to your Apple ID account at confirmation" : {
