    "three quiet minutes with Honestly, and the rest of the morning is yours again — calm, clear, present." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ثلاث دقائق هادئة مع Honestly، ويعود بقية الصباح لك — هادئًا وصافيًا وحاضرًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drei ruhige Minuten mit Honestly, und der Rest des Morgens gehört wieder dir — ruhig, klar, präsent."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tres minutos de calma con Honestly y el resto de la mañana vuelve a ser tuyo: tranquilo, claro, presente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trois minutes de calme avec Honestly, et le reste du matin t'appartient à nouveau — calme, clair, présent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tre minuti di calma con Honestly e il resto della mattina torna tuo — sereno, lucido, presente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Honestlyとの静かな3分で、朝の残りはまたあなたのもの — 穏やかに、澄んで、今ここに。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Honestly와 함께하는 고요한 3분이면, 남은 아침이 다시 당신의 것이 돼요 — 차분하고, 또렷하고, 현재에."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drie stille minuten met Honestly, en de rest van de ochtend is weer van jou — kalm, helder, aanwezig."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Três minutos de calma com o Honestly, e o resto da manhã é seu de novo — calmo, claro, presente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Três minutos de calma com o Honestly, e o resto da manhã volta a ser teu — calmo, claro, presente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Три тихие минуты с Honestly — и остаток утра снова твой: спокойный, ясный, настоящий."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "和 Honestly 共度三分钟的宁静，余下的早晨又重新属于你——平静、清晰、当下。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "和 Honestly 共度三分鐘的寧靜，餘下的早晨又重新屬於你——平靜、清晰、當下。"
          }
        }
      }
    },
