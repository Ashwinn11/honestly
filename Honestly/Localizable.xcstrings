    "show up every morning and watch it bloom. miss a day and it needs you back." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "احضر كل صباح وشاهدها تزهر. تغيب يومًا فتحتاجك من جديد."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei jeden Morgen da und sieh sie erblühen. Verpasst du einen Tag, braucht sie dich zurück."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "preséntate cada mañana y mírala florecer. si faltas un día, te necesita de vuelta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "sois là chaque matin et regarde-la fleurir. saute un jour, et elle a besoin que tu reviennes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "presentati ogni mattina e guardala fiorire. salta un giorno e ha bisogno che tu torni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "毎朝顔を出して、咲くのを見届けて。1日空けると、また戻ってきてほしがります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "매일 아침 들러서 피어나는 걸 지켜봐요. 하루 빠지면 당신을 다시 필요로 해요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "kom elke ochtend langs en zie hem bloeien. sla je een dag over, dan heeft hij je terug nodig."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "apareça toda manhã e veja-a florescer. se faltar um dia, ela precisa de você de volta."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "aparece todas as manhãs e vê-a florescer. se faltares um dia, ela precisa de ti de volta."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "приходи каждое утро и смотри, как оно цветёт. пропустишь день — ему снова нужен ты."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每天早晨都来，看它绽放。错过一天，它就需要你回来。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每天早晨都來，看它綻放。錯過一天，它就需要你回來。"
          }
        }
      }
    },
