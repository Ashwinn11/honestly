    "- Subscription renews automatically unless canceled at least 24 hours before the period ends" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- يتجدّد الاشتراك تلقائيًا ما لم يُلغَ قبل انتهاء الفترة بـ 24 ساعة على الأقل"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Das Abo verlängert sich automatisch, sofern es nicht mindestens 24 Stunden vor Ende des Zeitraums gekündigt wird"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- La suscripción se renueva automáticamente salvo que se cancele al menos 24 horas antes de que termine el periodo"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- L'abonnement se renouvelle automatiquement sauf annulation au moins 24 heures avant la fin de la période"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- L'abbonamento si rinnova automaticamente salvo annullamento almeno 24 ore prima della fine del periodo"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- 期間終了の24時間以上前に解約しない限り、サブスクリプションは自動更新されます"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- 기간 종료 최소 24시간 전에 취소하지 않으면 구독이 자동으로 갱신됩니다"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Het abonnement wordt automatisch verlengd tenzij het minstens 24 uur voor het einde van de periode wordt opgezegd"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- A assinatura é renovada automaticamente, a menos que seja cancelada pelo menos 24 horas antes do fim do período"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- A subscrição renova-se automaticamente, a menos que seja cancelada pelo menos 24 horas antes do fim do período"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Подписка продлевается автоматически, если не отменить её минимум за 24 часа до конца периода"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- 除非在当前周期结束前至少 24 小时取消，否则订阅将自动续期"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- 除非在當前週期結束前至少 24 小時取消，否則訂閱將自動續訂"
          }
        }
      }
    },
