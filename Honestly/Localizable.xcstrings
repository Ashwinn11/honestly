          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "lascia che proteggiamo la pace del tuo mattino"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたの朝の静けさを守らせてください"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신의 아침 평온을 지키게 해 주세요"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "laat ons je ochtendrust bewaken"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "deixe-nos proteger a paz da sua manhã"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "deixa-nos proteger a paz da tua manhã"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "позволь нам беречь покой твоего утра"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "让我们守护你早晨的宁静"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "讓我們守護你早晨的寧靜"
          }
        }
      }
    },
    "locked until you've had your three minutes. then they're yours — guilt-free." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مقفلة حتى تأخذ دقائقك الثلاث. ثم تصبح لك — بلا شعور بالذنب."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "gesperrt, bis du deine drei Minuten hattest. dann gehören sie dir — ganz ohne schlechtes Gewissen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bloqueadas hasta tus tres minutos. después son tuyas — sin culpa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "verrouillées jusqu'à tes trois minutes. ensuite elles sont à toi — sans culpabilité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bloccate finché non hai i tuoi tre minuti. poi sono tue — senza sensi di colpa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3分を終えるまでロック。そのあとは自由に — 罪悪感なしで。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3분을 끝낼 때까지 잠겨 있어요. 그다음엔 당신의 것 — 죄책감 없이."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "vergrendeld tot je je drie minuten hebt gehad. daarna zijn ze van jou — zonder schuldgevoel."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bloqueados até você ter seus três minutos. depois são seus — sem culpa."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bloqueados até teres os teus três minutos. depois são teus — sem culpa."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "заблокированы, пока не пройдут твои три минуты. потом они твои — без чувства вины."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在你完成三分钟之前一直锁定。之后它们就归你——毫无负担。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在你完成三分鐘之前一直鎖定。之後它們就歸你——毫無負擔。"
          }
        }
      }
    },
