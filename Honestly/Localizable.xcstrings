    "journal every day to grow. miss days and your plant gently steps back." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اكتب كل يوم لتنمو. إن غبت أيامًا تتراجع نبتتك بلطف."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schreibe jeden Tag, um zu wachsen. Lässt du Tage aus, geht deine Pflanze sanft zurück."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "escribe cada día para crecer. si faltas, tu planta retrocede suavemente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "écris chaque jour pour grandir. si tu sautes des jours, ta plante recule doucement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "scrivi ogni giorno per crescere. se salti dei giorni, la pianta torna gentilmente indietro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "毎日書いて育てましょう。書かない日が続くと、植物はそっと後戻りします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "매일 기록하면 자라요. 며칠 거르면 식물이 살며시 뒷걸음쳐요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "schrijf elke dag om te groeien. sla je dagen over, dan zakt je plant zachtjes terug."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "escreva todos os dias para crescer. se faltar, sua planta recua suavemente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "escreve todos os dias para crescer. se faltares, a tua planta recua suavemente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "пиши каждый день, чтобы расти. пропустишь дни — растение мягко отступит назад."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每天书写才能成长。中断几天，植物就会悄悄退回一些。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每天書寫才能成長。中斷幾天，植物就會悄悄退回一些。"
          }
        }
      }
    },
